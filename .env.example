# OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Serper API key for web search fallback
SERPER_API_KEY=your_serper_api_key_here

# Web server settings
SELF_RAG_HOST=127.0.0.1
SELF_RAG_PORT=8000
SELF_RAG_LOG_LEVEL=INFO

# Source document path
SELF_RAG_SOURCE_PATH=./data/SPRi AI Brief_10월호_산업동향_1002_F.pdf

# Retrieval settings
SELF_RAG_CHUNK_SIZE=1000
SELF_RAG_CHUNK_OVERLAP=100
SELF_RAG_TOP_K=3
SELF_RAG_MAX_RETRIES=2

# UI streaming settings
SELF_RAG_STREAM_CHUNK_SIZE=18
